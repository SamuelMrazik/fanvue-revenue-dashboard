PORT=4000
HTTPS_PORT=4443
HTTPS_KEY_PATH=certs/localhost-key.pem
HTTPS_CERT_PATH=certs/localhost-cert.pem
DASHBOARD_SECRET=replace-with-a-long-random-secret
DASHBOARD_USER=owner
DASHBOARD_PASSWORD=
AUTO_SYNC=true

# Fanvue OAuth. Keep the secret server-side only.
FANVUE_CLIENT_ID=
FANVUE_CLIENT_SECRET=
FANVUE_REDIRECT_URI=https://127.0.0.1:4443/api/fanvue/callback
FANVUE_SCOPES=openid offline_access offline read:self read:insights
FANVUE_API_VERSION=2025-06-26
FANVUE_API_BASE_URL=https://api.fanvue.com
FANVUE_METRICS_ENDPOINT=/insights/earnings/summary
